# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.env
.venv

# ── Jupyter Notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ── Data files (do NOT commit raw data to GitHub) ────────────────────────────
*.csv
*.xlsx
*.xls
*.json
*.parquet

# ── Exceptions: keep the model and scaler ────────────────────────────────────
# The .pkl files ARE intentionally tracked (they are needed for deployment)
!swiftchain_delay_predictor.pkl
!swiftchain_scaler.pkl

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

